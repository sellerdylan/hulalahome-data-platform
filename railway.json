{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && pip install --no-cache-dir -r requirements.txt",
    "startCommand": "cd server && python -m uvicorn main:app --host 0.0.0.0 --port ${PORT}"
  },
  "deploy": {
    "region": "us-east",
    "numReplicas": 1
  }
}
