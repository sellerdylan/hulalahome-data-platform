{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt",
    "startCommand": "python main.py"
  },
  "deploy": {
    "region": "us-east",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "env": {
    "PORT": {
      "description": "Railway auto-assigns this",
      "required": false
    }
  }
}
